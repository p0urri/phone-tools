#!/bin/bash

# Vérifier si le script est appelé avec "m4s" (via un alias ou lien symbolique)
if [[ "$0" == *"m4s" ]] || [[ "$1" == "m4s" ]]; then
    # Si appelé avec m4s, on lance le mode interactif
    exec "$0" "$@"
    exit 0
fi

# ============================================
# PHONE CONTROL - by m4s
# Version: 4.1.4 - Mode Interactif
# ============================================

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
DIM='\033[2m'
NC='\033[0m'

# Variables
CURRENT_IP=""
MSG_DIR="$HOME/phone_messages"
mkdir -p "$MSG_DIR"

# ============================================
# AFFICHAGE
# ============================================
