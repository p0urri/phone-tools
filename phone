    echo -e "${CYAN}"
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║     ██████╗ ██╗  ██╗ ██████╗ ███╗   ██╗███████╗              ║"
    echo "║     ██╔══██╗██║  ██║██╔═══██╗████╗  ██║██╔════╝              ║"
    echo "║     ██████╔╝███████║██║   ██║██╔██╗ ██║█████╗                ║"
    echo "║     ██╔═══╝ ██╔══██║██║   ██║██║╚██╗██║██╔══╝                ║"
    echo "║     ██║     ██║  ██║╚██████╔╝██║ ╚████║███████╗              ║"
    echo "║     ╚═╝     ╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═══╝╚══════╝              ║"
    echo "║                                                              ║"
    echo "║                    PHONE CONTROL v4.1.4                      ║"
    echo "║                    by m4s                                    ║"
